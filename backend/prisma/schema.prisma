generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  STAFF_ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  TWITTER
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum OrderType {
  MODEL_1 // Client brings fabric
  MODEL_2 // Designer sources fabric
  MODEL_3 // Ready-to-wear purchase
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING_REVIEW
  AWAITING_CLIENT_RESPONSE
  AGREED_AWAITING_PAYMENT
  IN_PROGRESS
  CUTTING
  SEWING
  FINISHING
  AWAITING_FINAL_PAYMENT
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum PaymentType {
  INSTALLMENT
  FULL
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TestimonialSource {
  CLIENT_SUBMITTED
  ADMIN_ADDED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ORDER_PLACED
  ORDER_STATUS_UPDATED
  PROJECT_STARTED
  READY_FOR_PICKUP
  PAYMENT_CONFIRMED
  PAYMENT_REJECTED
  NEW_MESSAGE
  MEASUREMENT_APPOINTMENT
  ACCOUNT_CREATED
}

model User {
  id               String       @id @default(cuid())
  fullName         String
  email            String       @unique
  phone            String?
  sex              Sex?
  dateOfBirth      DateTime?
  address          String?
  profilePicture   String?
  role             Role         @default(CLIENT)
  authProvider     AuthProvider @default(LOCAL)
  providerId       String?
  passwordHash     String?
  isEmailVerified  Boolean      @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiry DateTime?

  // Refresh token (two-token auth strategy)
  refreshToken       String? // bcrypt-hashed refresh token
  refreshTokenExpiry DateTime? // expiry stored for double-check validation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  measurements       Measurement[]
  orders             Order[]
  payments           Payment[]                @relation("ClientPayments")
  confirmedPayments  Payment[]                @relation("ConfirmedByAdmin")
  chatMessages       ChatMessage[]
  notifications      Notification[]
  testimonials       Testimonial[]
  appointments       MeasurementAppointment[]
  statusChanges      OrderStatusHistory[]
  createdClients     User[]                   @relation("AdminCreatedClients")
  createdBy          User?                    @relation("AdminCreatedClients", fields: [createdById], references: [id])
  createdById        String?
  adminCreatedOrders Order[]                  @relation("AdminCreatedOrders")
  cart               Cart?

  oauthCode       String? // short-lived one-time code for OAuth login
  oauthCodeExpiry DateTime?

  @@map("users")
}

model Measurement {
  id       String @id @default(cuid())
  clientId String

  // Core measurements (all in centimetres)
  bust               Float?
  waist              Float?
  hips               Float?
  shoulderWidth      Float?
  sleeveLength       Float?
  dressLength        Float?
  thigh              Float?
  inseam             Float?
  neck               Float?
  armLength          Float?
  armCircumference   Float?
  ankleCircumference Float?
  wristCircumference Float?
  backLength         Float?
  frontLength        Float?

  // Custom measurements the business may need beyond the standard set
  customParams Json? // e.g. { "rise": 28, "calf": 38 }

  // Audit trail
  updatedById        String? // who made the last update
  updatedByRole      String? // "CLIENT" or "ADMIN"
  disclaimerSignedAt DateTime? // when client signed the self-update disclaimer
  notes              String? // admin notes about this measurement record

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client  User                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders  Order[] // orders that used this measurement snapshot
  history MeasurementHistory[]

  @@map("measurements")
}

model Style {
  id                 String   @id @default(cuid())
  name               String
  description        String
  category           String // e.g. "Gowns", "Corporate", "Bridal"
  images             String[] // array of Cloudinary URLs
  availableForModel1 Boolean  @default(true) // client brings fabric
  availableForModel2 Boolean  @default(true) // designer sources fabric
  isFeatured         Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders Order[]

  @@map("styles")
}

model ReadyToWear {
  id               String   @id @default(cuid())
  name             String
  description      String
  price            Decimal  @db.Decimal(10, 2)
  category         String
  images           String[] // array of Cloudinary URLs
  availableSizes   String[] // e.g. ["S", "M", "L", "XL"] or ["36", "38", "40"]
  fabricDetails    String?
  careInstructions String?
  stockStatus      String   @default("IN_STOCK") // IN_STOCK | LOW_STOCK | OUT_OF_STOCK
  stockCount       Int      @default(0)
  isFeatured       Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@map("ready_to_wear")
}

model Order {
  id          String    @id @default(cuid())
  orderNumber String    @unique // human-readable e.g. "ORD-2026-0042"
  clientId    String
  orderType   OrderType

  // Style reference — one of these will be set depending on order type
  styleId                String? // links to a curated Style
  customStyleDescription String? // client's description for custom style
  customStyleImages      String[] // reference images uploaded by client

  // Fabric
  clientProvidesFabric Boolean @default(false)
  fabricNotes          String? // notes about fabric (colour, type, quantity)

  // Measurements
  measurementId String? // snapshot of measurements used for this order

  // Fulfillment
  fulfillmentMethod FulfillmentMethod @default(PICKUP)
  deliveryAddress   String?
  deliveryFee       Decimal?          @db.Decimal(10, 2)

  // Pricing
  totalAgreedFee Decimal? @db.Decimal(10, 2)
  totalPaid      Decimal  @default(0) @db.Decimal(10, 2)

  // Status & notes
  status             OrderStatus @default(PENDING_REVIEW)
  clientNotes        String? // notes from client at order time
  adminNotes         String? // internal notes from admin
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client           User         @relation(fields: [clientId], references: [id])
  style            Style?       @relation(fields: [styleId], references: [id])
  items            OrderItem[]
  measurement      Measurement? @relation(fields: [measurementId], references: [id])
  createdByAdminId String?
  createdByAdmin   User?        @relation("AdminCreatedOrders", fields: [createdByAdminId], references: [id])

  payments       Payment[]
  chatMessages   ChatMessage[]
  statusHistory  OrderStatusHistory[]
  portfolioEntry Portfolio?
  notifications  Notification[]

  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  readyToWearId   String
  selectedSize    String
  quantity        Int      @default(1)
  priceAtPurchase Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  readyToWear ReadyToWear @relation(fields: [readyToWearId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  changedById String
  note        String? // optional note explaining the status change
  createdAt   DateTime    @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation(fields: [changedById], references: [id])

  @@map("order_status_history")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  clientId        String
  amount          Decimal       @db.Decimal(10, 2)
  paymentType     PaymentType
  proofUrl        String? // Cloudinary URL of transfer receipt
  status          PaymentStatus @default(PENDING)
  confirmedById   String? // Super Admin who confirmed
  confirmedAt     DateTime?
  rejectionReason String?
  notes           String? // e.g. "First installment", "Final payment"
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order       Order @relation(fields: [orderId], references: [id])
  client      User  @relation("ClientPayments", fields: [clientId], references: [id])
  confirmedBy User? @relation("ConfirmedByAdmin", fields: [confirmedById], references: [id])

  @@map("payments")
}

model ChatMessage {
  id          String    @id @default(cuid())
  orderId     String
  senderId    String
  senderRole  Role
  message     String?
  attachments String[] // Cloudinary URLs for images sent in chat
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  message        String
  isRead         Boolean          @default(false)
  relatedOrderId String?
  createdAt      DateTime         @default(now())

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedOrder Order? @relation(fields: [relatedOrderId], references: [id])

  @@map("notifications")
}

model Testimonial {
  id         String            @id @default(cuid())
  clientId   String? // null if added by admin for anonymous offline client
  clientName String // display name (can be "Anonymous")
  rating     Int // 1–5
  review     String
  photoUrl   String? // Cloudinary URL
  source     TestimonialSource @default(CLIENT_SUBMITTED)
  status     TestimonialStatus @default(PENDING)
  isFeatured Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  client User? @relation(fields: [clientId], references: [id])

  @@map("testimonials")
}

model Portfolio {
  id            String   @id @default(cuid())
  orderId       String?  @unique // optional — standalone entries allowed for past work
  title         String?
  description   String?
  category      String
  images        String[] // Cloudinary URLs — multiple angles
  clientConsent Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id])

  @@map("portfolio")
}

model MeasurementAppointment {
  id            String            @id @default(cuid())
  clientId      String
  requestedDate DateTime? // client's preferred date/time
  confirmedDate DateTime? // admin-confirmed date/time
  status        AppointmentStatus @default(REQUESTED)
  clientNotes   String?
  adminNotes    String?
  cancelReason  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client User @relation(fields: [clientId], references: [id])

  @@map("measurement_appointments")
}

model MeasurementHistory {
  id            String @id @default(cuid())
  measurementId String
  clientId      String

  // Snapshot of what changed — stores only the fields that were updated
  changedFields Json // e.g. { "bust": { "from": 88, "to": 90 }, "waist": { "from": 70, "to": 72 } }

  updatedById        String
  updatedByRole      String // "CLIENT" | "STAFF_ADMIN" | "SUPER_ADMIN"
  updatedByName      String // denormalised for display — avoids extra join
  disclaimerSignedAt DateTime?
  notes              String?

  createdAt DateTime @default(now())

  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)

  @@map("measurement_history")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique // one cart per user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  readyToWearId String
  selectedSize  String // "S", "M", "L", etc.
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart        Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  readyToWear ReadyToWear @relation(fields: [readyToWearId], references: [id])

  @@unique([cartId, readyToWearId, selectedSize]) // prevent duplicate entries for same item+size
  @@map("cart_items")
}
