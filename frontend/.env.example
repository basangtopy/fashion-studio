# Backend URL for OAuth redirects (full-page navigation, not API calls)
# In production, set to your deployed backend URL (e.g. https://api.yourdomain.com/api)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api

# Backend URL for Next.js rewrites (server-side proxy)
# In production, set to your deployed backend URL (e.g. https://api.yourdomain.com)
BACKEND_URL=http://localhost:5000
